public class EditItemActivity extends AppCompatActivity {
    private String title_str;
    private String maker_str;
    private String description_str;
    private String length_str;
    private String width_str;
    private String height_str;
    private EditText title;
    private EditText maker;
    private EditText description;
    private EditText length;
    private EditText width;
    private EditText height;

    // ... onCreate initializes all fields ...

    public boolean validateInput() {
        title_str = title.getText().toString();
        maker_str = maker.getText().toString();
        description_str = description.getText().toString();
        length_str = length.getText().toString();
        width_str = width.getText().toString();
        height_str = height.getText().toString();

        if (title_str.equals("")) {
            title.setError("Empty field!");
            return false;
        }
        if (maker_str.equals("")) {
            maker.setError("Empty field!");
            return false;
        }
        if (description_str.equals("")) {
            description.setError("Empty field!");
            return false;
        }
        // Dimensions check
        if (length_str.equals("")) { length.setError("Empty!"); return false; }
        if (width_str.equals("")) { width.setError("Empty!"); return false; }
        if (height_str.equals("")) { height.setError("Empty!"); return false; }
        
        return true;
    }

    public void saveItem(View view) {
        if (!validateInput()) {
            return;
        }
        // Edit logic code...
        finish();
    }
}
